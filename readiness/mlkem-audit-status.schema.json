{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "mlkem-kit audit gate status",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "packageScope", "sourceCommit", "productionFallbackStatus", "gates"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "packageScope": { "const": "ML-KEM-768 confidentiality fallback readiness" },
    "sourceCommit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "productionFallbackStatus": { "enum": ["fail-closed", "risk-accepted", "approved"] },
    "productionFallbackRiskAcceptance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "decisionOwner", "acceptedAt", "scope", "evidence", "constraints", "nonClaims"],
      "properties": {
        "status": { "const": "accepted" },
        "decisionOwner": { "type": "string", "minLength": 1 },
        "acceptedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "scope": { "type": "string", "minLength": 1 },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "constraints": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "nonClaims": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "gates": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "reviewer", "reviewedAt", "evidence", "blockers"],
        "properties": {
          "id": {
            "enum": [
              "fips203-code-map-review",
              "side-channel-review",
              "secret-lifetime-review",
              "external-crypto-review"
            ]
          },
          "status": { "enum": ["open", "closed"] },
          "reviewer": { "type": "string" },
          "reviewedAt": { "type": "string" },
          "evidence": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "blockers": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
