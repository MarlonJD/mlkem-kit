{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "mlkem-kit release-device benchmark results",
  "type": "object",
  "required": ["schemaVersion", "status", "results"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "status": { "enum": ["missing", "partial", "complete"] },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "platform",
          "device",
          "osOrRuntime",
          "buildConfiguration",
          "providerId",
          "keyGenerationP50Ms",
          "encapsulationP50Ms",
          "decapsulationP50Ms",
          "peakAllocationBytes",
          "sampleCount",
          "measuredAt"
        ],
        "properties": {
          "platform": { "enum": ["iOS", "macOS", "Android", "dotnet"] },
          "device": { "type": "string", "minLength": 1 },
          "osOrRuntime": { "type": "string", "minLength": 1 },
          "buildConfiguration": { "enum": ["release"] },
          "providerId": { "type": "string", "minLength": 1 },
          "keyGenerationP50Ms": { "type": "number", "minimum": 0 },
          "encapsulationP50Ms": { "type": "number", "minimum": 0 },
          "decapsulationP50Ms": { "type": "number", "minimum": 0 },
          "peakAllocationBytes": { "type": "integer", "minimum": 0 },
          "sampleCount": { "type": "integer", "minimum": 100 },
          "measuredAt": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
